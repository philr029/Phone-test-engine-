# Twilio credentials (required for live calls)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Public base URL of this server (required for Twilio webhook callbacks in live mode)
# For local development use ngrok: https://your-id.ngrok.io
# For Vercel/cloud deployment: https://your-app.vercel.app
BASE_URL=http://localhost:3000

# Server port (default: 3000)
PORT=3000

# Set to "true" to simulate calls without real Twilio API usage
TEST_MODE=false

# Optional: Custom TwiML URL Twilio fetches when the call connects
# Defaults to the Twilio demo voice XML
# TWIML_URL=https://your-app.example.com/twiml
